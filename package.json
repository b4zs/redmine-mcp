{
  "name": "@a-bonus/redmine-mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for Redmine (issues + time entries)",
  "author": "a-bonus",
  "license": "ISC",
  "bin": {
    "redmine-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node ./dist/index.js",
    "build": "tsc",
    "dev": "tsx ./src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "mcp",
    "redmine",
    "issues",
    "time-entries"
  ],
  "dependencies": {
    "fastmcp": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
